generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Teacher
  Student
}

model User {
  id               String          @id @default(cuid())
  role             Role
  name             String
  email            String          @unique
  username         String          @unique
  password         String
  title            String
  taughtClasses    Class[]         @relation("TeacherClasses")
  classEnrollments ClassStudent[]
  gradesGiven      Grade[]         @relation("TeacherGrades")
  gradesReceived   Grade[]         @relation("StudentGrades")
  scheduleEntries  ScheduleEntry[]
  projects         Project[]

  @@index([role])
}

model Class {
  id        String         @id @default(cuid())
  subject   String
  code      String         @unique
  section   String
  teacherId String?
  room      String
  schedule  String
  teacher   User?          @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  students  ClassStudent[]

  @@index([teacherId])
}

model ClassStudent {
  classId    String
  studentId  String
  class      Class @relation(fields: [classId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  student    User  @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([classId, studentId])
  @@index([studentId])
}

model Grade {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  subject   String
  grade     String
  date      DateTime
  teacher   User     @relation("TeacherGrades", fields: [teacherId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  student   User     @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([date])
}

model ScheduleEntry {
  id        String   @id @default(cuid())
  teacherId String
  day       String
  time      String
  subject   String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([teacherId])
  @@unique([teacherId, day, time])
}

model Project {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String
  dueDate     DateTime
  status      String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([studentId])
  @@index([dueDate])
}
